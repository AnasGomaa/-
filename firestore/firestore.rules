rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userRole() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return userRole() == "admin";
    }

    function isTeacher() {
      return userRole() == "teacher" || isAdmin();
    }

    function isStudentOwner(studentId) {
      return userRole() == "student"
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.studentId == studentId;
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isTeacher());
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isTeacher() || isStudentOwner(studentId);
      allow create, update, delete: if isTeacher();
    }

    match /transactions/{transactionId} {
      allow read: if isTeacher() || isStudentOwner(resource.data.studentId);
      allow create: if isTeacher();
      allow update, delete: if isAdmin();
    }

    match /rewards/{rewardId} {
      allow read: if signedIn();
      allow write: if isTeacher();
    }

    match /notifications/{notificationId} {
      allow read, update: if isTeacher() || isStudentOwner(resource.data.studentId);
      allow create, delete: if isTeacher();
    }
  }
}
