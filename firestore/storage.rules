rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /students/{studentId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && request.resource.size < 3 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /settings/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && request.resource.size < 2 * 1024 * 1024;
    }
  }
}
